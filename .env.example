# Anthropic — for extraction and English brief generation
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenRouter — for Arabic brief generation (Qwen-72B, free tier available)
OPENROUTER_API_KEY=sk-or-your-key-here

# OpenAI — for embeddings (text-embedding-3-small) and eval judge (gpt-4o-mini)
OPENAI_API_KEY=sk-your-key-here

# Model config
EXTRACTION_MODEL=claude-haiku-4-5-20251001
GENERATION_MODEL_EN=claude-haiku-4-5-20251001
GENERATION_MODEL_AR=qwen/qwen2.5-72b-instruct
JUDGE_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Paths
CHROMA_PERSIST_DIR=./chroma_db
GRAPH_PATH=./graph/parenting_graph.json
DATA_DIR=./data

# API
CORS_ORIGINS=http://localhost:3000
