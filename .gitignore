# =============================================================================
# Perfect .gitignore for Python + Vite/React projects
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
env/
ENV/
.venv

# pip
*.egg-info/
pip-log.txt
pip-delete-this-directory.txt

# pytest
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# ruff
.ruff_cache/

# -----------------------------------------------------------------------------
# Node.js / Vite / React
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Build outputs
dist/
dist-ssr/
*.local

# Environment files
.env
.env.local
.env.example.bak
.env.development.local
.env.test.local
.env.production.local

# Editor directories and files
.idea/
.vscode/*
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/

# -----------------------------------------------------------------------------
# Documentation (generated docs)
# -----------------------------------------------------------------------------
docs/
docs/_build/
docs/.sphinx/
docs/generated/

# -----------------------------------------------------------------------------
# Data files (keep these in git for now, but ignore runtime data)
# -----------------------------------------------------------------------------
data/*.json
!data/*.json.example

# -----------------------------------------------------------------------------
# Temporary files
# -----------------------------------------------------------------------------
*.tmp
*.temp
tmp/
temp/